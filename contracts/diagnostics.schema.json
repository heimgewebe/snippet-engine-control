{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://snippet-engine-control.local/diagnostics.schema.json",
  "title": "Diagnostics",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "triggerCollisions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "ambiguousBoundaries": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "encodingIssues": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "unsupportedFeatures": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  },
  "required": [
    "triggerCollisions",
    "ambiguousBoundaries",
    "encodingIssues",
    "unsupportedFeatures"
  ]
}
