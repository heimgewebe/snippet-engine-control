{
  "$id": "https://snippet-engine-control.org/schema/ui-api.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI API Schema",
  "description": "JSON Schema for API interactions. NOTE: All state-changing endpoints must include the X-SEC-Token header for security.",
  "oneOf": [
    { "$ref": "#/$defs/ValidationResponse" },
    { "$ref": "#/$defs/PreviewResponse" },
    { "$ref": "#/$defs/SnippetListResponse" },
    { "$ref": "snippet.schema.json" }
  ],
  "$defs": {
    "SnippetListResponse": {
      "type": "array",
      "items": {
        "$ref": "snippet.schema.json"
      }
    },
    "ValidationResponse": {
      "type": "object",
      "properties": {
        "conflicts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boundaries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "encodings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["conflicts", "boundaries", "encodings"],
      "additionalProperties": false
    },
    "PreviewResponse": {
      "type": "object",
      "properties": {
        "preview": { "type": "string" }
      },
      "required": ["preview"],
      "additionalProperties": false
    }
  }
}
