{
  "$id": "https://snippet-engine-control.org/schema/ui-api.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI API Schema",
  "type": "object",
  "description": "Container for UI API payload definitions. Use $ref into $defs for specific endpoints. NOTE: All state-changing endpoints must include the X-SEC-Token header for security.",
  "$defs": {
    "SnippetListResponse": {
      "type": "array",
      "items": {
        "$ref": "https://snippet-engine-control.local/snippet.schema.json"
      }
    },
    "ValidationResponse": {
      "type": "object",
      "properties": {
        "conflicts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boundaries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "encodings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["conflicts", "boundaries", "encodings"],
      "additionalProperties": false
    },
    "PreviewResponse": {
      "type": "object",
      "properties": {
        "preview": { "type": "string" }
      },
      "required": ["preview"],
      "additionalProperties": false
    }
  }
}
